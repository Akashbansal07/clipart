{
  "expo": {
    "name": "AI Clipart App",
    "slug": "clipart-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clipartapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clipartapp.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "AI Clipart App needs access to your photo library to select images for clipart generation.",
        "NSCameraUsageDescription": "AI Clipart App needs access to your camera to capture images for clipart generation.",
        "NSPhotoLibraryAddUsageDescription": "AI Clipart App needs access to save generated clipart to your photo library."
      }
    },
    "android": {
      "package": "com.clipartapp.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "AI Clipart App needs access to your photos to select images for clipart generation.",
          "cameraPermission": "AI Clipart App needs access to your camera to capture images for clipart generation."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "AI Clipart App needs access to your photos to view and select images.",
          "savePhotosPermission": "AI Clipart App needs permission to save generated clipart to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "428e2468-46ff-468d-913c-ecb6dcfe5eec"
      }
    }
  }
}